<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alophia.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="24" MinWidth="400">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Alophia" FontSize="32" FontWeight="Bold" TextAlignment="Center"/>
                <TextBlock Text="Project Pipeline Manager" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center"/>
            </StackPanel>

            <Button x:Name="LoadProjectButton" Content="Load Existing Project" Height="60" FontSize="16" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            <Button x:Name="CreateProjectButton" Content="Create New Project" Height="60" FontSize="16" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
