<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alophia.Views.NewProjectWizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="40">
        <StackPanel MaxWidth="600" VerticalAlignment="Center" Spacing="24">
            <!-- Step Indicator -->
            <StackPanel Spacing="12">
                <TextBlock x:Name="StepTitle" FontSize="24" FontWeight="Bold"/>
                <ProgressBar x:Name="StepProgress" Height="4"/>
            </StackPanel>

            <!-- Step 1: Project Name -->
            <StackPanel x:Name="Step1" Spacing="12">
                <TextBlock Text="Project Name" FontSize="16" FontWeight="SemiBold"/>
                <TextBox x:Name="ProjectNameBox" PlaceholderText="e.g. MyPipeline" Padding="12,10"/>

                <TextBlock Text="Project Folder" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,0"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0" x:Name="FolderPathBox" PlaceholderText="Click Browse to select folder" IsReadOnly="True" Padding="12,10"/>
                    <Button Grid.Column="1" x:Name="BrowseFolderButton" Content="Browse" Padding="24,10" Width="100"/>
                </Grid>
            </StackPanel>

            <!-- Step 2: Select Project Folders -->
            <StackPanel x:Name="Step2" Spacing="12">
                <TextBlock Text="Select Project Folders" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="Check the folders that represent your project stages:" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ScrollViewer Height="300">
                    <ItemsControl x:Name="FoldersList"/>
                </ScrollViewer>
            </StackPanel>

            <!-- Step 3: Summary -->
            <StackPanel x:Name="Step3" Spacing="12">
                <TextBlock Text="Review &amp; Create" FontSize="16" FontWeight="SemiBold"/>
                <StackPanel Background="{ThemeResource ControlFillColorDefaultBrush}" Padding="16" CornerRadius="4" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Project:" FontWeight="SemiBold" MinWidth="100"/>
                        <TextBlock x:Name="SummaryProjectName"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Folder:" FontWeight="SemiBold" MinWidth="100"/>
                        <TextBlock x:Name="SummaryFolder"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Stages:" FontWeight="SemiBold" MinWidth="100"/>
                        <TextBlock x:Name="SummaryStages"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Navigation Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button x:Name="BackButton" Content="Back" Padding="20,10" Style="{ThemeResource ButtonRevealStyle}"/>
                <Button x:Name="NextButton" Content="Next" Padding="20,10"/>
                <Button x:Name="CreateButton" Content="Create Project" Padding="20,10"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
