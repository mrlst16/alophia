<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alophia.Views.DiffPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="168"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Repositories Panel -->
        <Grid Grid.Column="0" BorderThickness="0,0,0.5,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <StackPanel Padding="12">
                <TextBlock Text="Repositories" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="State Filings" FontSize="13" Padding="10,8" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="3 commits" FontSize="11" Padding="10,0" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="State Filings API" FontSize="13" Padding="10,8" Margin="0,8,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="3 commits" FontSize="11" Padding="10,0" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Column="1" Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- Commits Panel -->
        <Grid Grid.Column="2" BorderThickness="0,0,0.5,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <StackPanel Padding="12">
                <TextBlock Text="Commits" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="Add FilingsPage" FontSize="12" Padding="10,6" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="a1b2c3d w6" FontSize="11" Padding="10,0" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="Wire up useFilings" FontSize="12" Padding="10,8,10,6" Margin="0,8,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="d4e5f6a w7" FontSize="11" Padding="10,0" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Column="3" Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- Diff Panel -->
        <Grid Grid.Column="4" Padding="14">
            <StackPanel Spacing="12">
                <TextBlock Text="pages/filings/index.tsx" FontSize="12" FontFamily="Courier New" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Border Background="{ThemeResource ControlFillColorDefaultBrush}" Padding="10" CornerRadius="4">
                    <StackPanel Spacing="2">
                        <TextBlock Text="+  export default function FilingsPage() {" FontSize="12" FontFamily="Courier New" Foreground="#10B981"/>
                        <TextBlock Text="+    return &lt;FilingsTable data={useFilings()} /&gt;" FontSize="12" FontFamily="Courier New" Foreground="#10B981"/>
                        <TextBlock Text="+  }" FontSize="12" FontFamily="Courier New" Foreground="#10B981"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
