<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alophia.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Bot Sidebar -->
        <Grid Grid.Column="0" Background="{ThemeResource ControlFillColorSecondaryBrush}" BorderThickness="0,0,0.5,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <StackPanel Padding="12">
                <TextBlock Text="Direct Messages" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                <!-- Bot Item -->
                <Grid Padding="8" CornerRadius="4" Background="{ThemeResource ControlFillColorDefaultBrush}" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="30" Height="30" Fill="#FAEEDA" Stroke="#BA7517" StrokeThickness="2"/>
                    <TextBlock Grid.Column="1" Text="BB" HorizontalTextAlignment="Center" VerticalAlignment="Center" Foreground="#BA7517" FontWeight="SemiBold"/>
                    <StackPanel Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="BeckyBot" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="active" FontSize="11" Foreground="#1D9E75"/>
                    </StackPanel>
                </Grid>

                <Grid Padding="8" CornerRadius="4" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="30" Height="30" Fill="#FAECE7"/>
                    <TextBlock Grid.Column="1" Text="UX" HorizontalTextAlignment="Center" VerticalAlignment="Center" Foreground="#993C1D" FontWeight="SemiBold"/>
                    <StackPanel Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="UXBot" FontSize="13"/>
                        <TextBlock Text="idle" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Column="1" Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- Chat Area -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="12" BorderThickness="0,0,0,0.5" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Ellipse Width="28" Height="28" Fill="#FAEEDA"/>
                    <TextBlock Text="BB" HorizontalTextAlignment="Center" VerticalAlignment="Center" Foreground="#BA7517" FontWeight="SemiBold"/>
                    <TextBlock Text="BeckyBot" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="16" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Ellipse Width="32" Height="32" Fill="#FAEEDA"/>
                        <StackPanel VerticalAlignment="Top" Spacing="4">
                            <TextBlock Text="BeckyBot" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}" Padding="12,8" CornerRadius="8">
                                <TextBlock Text="Requirements locked. 12 stories, 3 epics. Let me know if scope changes."
                                           FontSize="14" TextWrapping="Wrap" MaxWidth="400"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <StackPanel VerticalAlignment="Top" Spacing="4" HorizontalAlignment="Right">
                            <TextBlock Text="You" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextAlignment="Right"/>
                            <Border Background="#0078D4" Padding="12,8" CornerRadius="8">
                                <TextBlock Text="Sounds good, let's get started!" Foreground="White"
                                           FontSize="14" TextWrapping="Wrap" MaxWidth="400"/>
                            </Border>
                        </StackPanel>
                        <Ellipse Width="32" Height="32" Fill="#E6F1FB"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Input -->
            <Grid Grid.Row="2" Padding="12" BorderThickness="0,0.5,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" PlaceholderText="Message BeckyBot..." Padding="12,8"/>
                <Button Grid.Column="1" Content="Send" Margin="8,0,0,0" Padding="12,6"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
