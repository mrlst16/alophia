<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alophia.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Grid Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,0.5" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock x:Name="PipelineTitle" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="WeekIndicator" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            </StackPanel>
        </Grid>

        <!-- Tabs -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Headers -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" BorderThickness="0,0,0,0.5" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Button x:Name="RequirementsTab" Content="Requirements" Style="{ThemeResource ButtonRevealStyle}" Padding="16,10" FontSize="13" Background="Transparent"/>
                <Button x:Name="StagesTab" Content="Stages" Style="{ThemeResource ButtonRevealStyle}" Padding="16,10" FontSize="13" Background="Transparent"/>
                <Button x:Name="ArchitectureTab" Content="Architecture" Style="{ThemeResource ButtonRevealStyle}" Padding="16,10" FontSize="13" Background="Transparent"/>
                <Button x:Name="DiffTab" Content="Diff" Style="{ThemeResource ButtonRevealStyle}" Padding="16,10" FontSize="13" Background="Transparent"/>
                <Button x:Name="ChatTab" Content="Chat" Style="{ThemeResource ButtonRevealStyle}" Padding="16,10" FontSize="13" Background="Transparent"/>
            </StackPanel>

            <!-- Tab Content -->
            <Frame x:Name="TabContent" Grid.Row="1"/>
        </Grid>
    </Grid>
</Page>
